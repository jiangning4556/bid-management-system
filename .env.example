# ==============================================
# Docker Compose 环境变量配置
# 部署前复制此文件为 .env 并修改配置
# ==============================================

# ============================================
# MySQL 配置
# ============================================
MYSQL_ROOT_PASSWORD=your-strong-root-password-change-me
MYSQL_PASSWORD=your-strong-password-change-me
MYSQL_PORT=3306

# ============================================
# JWT 密钥配置
# ============================================
# 使用以下命令生成强随机密钥：
# openssl rand -base64 64
JWT_SECRET=your-jwt-secret-key-change-me-use-openssl-rand-base64-64

# ============================================
# 端口配置
# ============================================
# 后端端口（开发时可暴露，生产环境建议通过 Nginx 代理）
BACKEND_PORT=3000

# 前端端口（开发时可暴露，生产环境建议通过 Nginx 代理）
FRONTEND_PORT=80

# Nginx 端口（使用 Nginx 代理时配置）
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

# ============================================
# 前端 API 地址
# ============================================
# 生产环境使用相对路径 /api（通过 Nginx 代理）
# 开发环境可以使用完整 URL
VITE_API_BASE_URL=/api

# ============================================
# 后端 CORS 配置
# ============================================
# 允许访问后端的前端域名（用于 CORS 配置）
FRONTEND_URL=http://bid.xjznpt.com
