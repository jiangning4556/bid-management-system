{
  "apps": [
    {
      "name": "bid-management-backend",
      "script": "dist/main.js",
      "cwd": "/var/www/bid-management/backend",
      "instances": 2,
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3000
      },
      "error_file": "/var/log/bid-management/error.log",
      "out_file": "/var/log/bid-management/out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s",
      "max_memory_restart": "1G",
      "watch": false
    }
  ]
}
